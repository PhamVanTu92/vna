generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── License ───────────────────────────────────────────────────────────────────
model License {
  id           Int      @id @default(1)
  licenseKey   String
  customerId   String
  customerName String
  issuedAt     DateTime
  expiresAt    DateTime
  maxUsers     Int
  product      String
  activatedAt  DateTime @default(now())
  activatedBy  Int?
  @@map("license")
}

model LicenseClock {
  id         Int      @id @default(1)
  lastSeenAt DateTime @default(now())
  tickCount  Int      @default(0)
  @@map("license_clock")
}

// ── Organisation ──────────────────────────────────────────────────────────────
model Branch {
  id          Int      @id @default(autoincrement())
  parentId    Int?
  parent      Branch?  @relation("BranchTree", fields: [parentId], references: [id])
  children    Branch[] @relation("BranchTree")
  name        String
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  settings  BranchSettings?
  users     User[]
  documents OcrDocument[]

  @@map("branches")
}

model BranchSettings {
  id           Int      @id @default(autoincrement())
  branchId     Int      @unique
  branch       Branch   @relation(fields: [branchId], references: [id])
  systemPrompt String?  // null = dùng DEFAULT_SYSTEM_PROMPT
  geminiModel  String   @default("gemini-3-pro-preview")
  updatedAt    DateTime @updatedAt
  updatedById  Int?

  @@map("branch_settings")
}

// ── Users ─────────────────────────────────────────────────────────────────────
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  fullName     String
  role         String   @default("user")  // system_admin | branch_admin | user
  branchId     Int?
  branch       Branch?  @relation(fields: [branchId], references: [id])
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  documents OcrDocument[] @relation("DocumentUploader")

  @@map("users")
}

// ── OCR Documents ─────────────────────────────────────────────────────────────
model OcrDocument {
  id           Int       @id @default(autoincrement())
  branchId     Int
  branch       Branch    @relation(fields: [branchId], references: [id])
  uploadedById Int
  uploadedBy   User      @relation("DocumentUploader", fields: [uploadedById], references: [id])
  fileName     String
  fileSize     Int       @default(0)
  period       String?   // "2025-04"
  status       String    @default("completed")  // processing | completed | error
  result       String    @default("[]") // JSON string của LineItem[]
  geminiModel  String    @default("")
  tokensUsed   Int?
  costUsd      Float?
  exportedAt   DateTime?
  createdAt    DateTime  @default(now())

  reconcileResult ReconcileResult?

  @@map("ocr_documents")
}

// ── Reconcile ─────────────────────────────────────────────────────────────────
model ReconcileResult {
  id            Int       @id @default(autoincrement())
  documentId    Int       @unique
  branchId      Int
  ocrAmount     Float
  gasAmount     Float?
  gasRef        String?
  difference    Float     @default(0)
  status        String    @default("not_found")
  aiConfidence  Float     @default(0)
  flagReason    String?
  flagNote      String?
  approvedById  Int?
  approvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  document      OcrDocument @relation(fields: [documentId], references: [id])

  @@map("reconcile_results")
}

// ── Prompt Config ─────────────────────────────────────────────────────────────
model PromptConfig {
  id          Int      @id @default(autoincrement())
  branchId    Int
  docType     String
  name        String
  promptText  String
  testScore   Float?
  testTotal   Int?
  testCorrect Int?
  isActive    Boolean  @default(true)
  updatedById Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([branchId, docType])
  @@map("prompt_configs")
}

// ── Integration Config ────────────────────────────────────────────────────────
model IntegrationConfig {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  displayName String
  isActive    Boolean   @default(false)
  config      String    @default("{}")
  lastSyncAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("integration_configs")
}

// ── Input Config ──────────────────────────────────────────────────────────────
model InputConfig {
  id              Int      @id @default(autoincrement())
  branchId        Int
  docType         String
  fieldMappings   String   @default("[]")
  acceptedFormats String   @default("[\"pdf\",\"xlsx\",\"jpg\"]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([branchId, docType])
  @@map("input_configs")
}

// ── Output Config ─────────────────────────────────────────────────────────────
model OutputConfig {
  id                  Int      @id @default(autoincrement())
  branchId            Int      @unique
  templateName        String   @default("CV2006_Template_VNA_v3.xlsx")
  startRow            Int      @default(5)
  currencyFormat      String   @default("¥ #,##0.00")
  dateFormat          String   @default("YYYY-MM-DD")
  includeAIConfidence Boolean  @default(true)
  includeAuditTrail   Boolean  @default(true)
  columnMapping       String   @default("[]")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("output_configs")
}

// ── Recon Config ──────────────────────────────────────────────────────────────
model ReconConfig {
  id              Int      @id @default(autoincrement())
  branchId        Int      @unique
  matchKeys       String   @default("[\"invoice_number\",\"vendor\",\"period\"]")
  tolerancePct    Float    @default(0.5)
  toleranceAmt    Float    @default(1000)
  onNotFound      String   @default("mark_new")
  autoApproveConf Float    @default(99.0)
  autoAfterOcr    Boolean  @default(true)
  scheduleBatch   Boolean  @default(true)
  scheduleType    String   @default("daily_0200")
  maxTimeoutSec   Int      @default(30)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("recon_configs")
}

// ── Audit Log ─────────────────────────────────────────────────────────────────
model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  userId    Int?
  branchId  Int?
  detail    String
  metadata  String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}
