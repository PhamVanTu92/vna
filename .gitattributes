# Tự động normalize line endings
* text=auto

# Shell scripts LUÔN dùng LF (chạy trên Linux Ubuntu)
*.sh text eol=lf

# Các file text thông thường
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.cjs  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.env* text eol=lf
*.pem  text eol=lf

# Binary files — không touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
